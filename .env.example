# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ibe_user:ibe_pass@localhost:5432/ibe_db"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── HyperGuest API ────────────────────────────────────────────────────────────
# Obtain from your HyperGuest account manager
HYPERGUEST_BEARER_TOKEN=""
HYPERGUEST_SEARCH_DOMAIN=""
HYPERGUEST_BOOKING_DOMAIN=""
HYPERGUEST_STATIC_DOMAIN=""

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="development"

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000"

# ── JWT (for future B2B auth) ─────────────────────────────────────────────────
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_DEFAULT_CURRENCY="EUR"

# ── Payment Gateway ───────────────────────────────────────────────────────────
# Which payment gateway to use. Default: stripe
# To switch gateway: set to another registered name (e.g. 'paypal', 'adyen')
PAYMENT_GATEWAY="stripe"

# ── Stripe (Payment) ──────────────────────────────────────────────────────────
# Test mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET=""

# ── Frontend Stripe ────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Search Cache TTL (seconds) ────────────────────────────────────────────────
SEARCH_CACHE_TTL=300
STATIC_DATA_CACHE_TTL=86400
