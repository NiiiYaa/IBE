# URL of the IBE API
IBE_API_URL=http://localhost:3001

# Property this bot serves (required)
PROPERTY_ID=12345

# Org ID (optional — enables chain-aware AI context)
# ORG_ID=1

# Port this service listens on
PORT=3002

# Where to persist the WhatsApp session (so you don't re-scan QR on restart)
SESSION_PATH=./.wwebjs_session
