  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

// ── Groups ────────────────────────────────────────────────────────────────────

model GroupConfig {
  id                          Int          @id @default(autoincrement())
  organizationId              Int          @unique
  organization                Organization @relation(fields: [organizationId], references: [id])
  enabled                     Boolean      @default(false)
  bookingMode                 String       @default("offline") // "online" | "offline"
  groupEmail                  String?
  pricingDirection            String       @default("decrease") // "increase" | "decrease"
  pricingPct                  Decimal      @default(0) @db.Decimal(5, 2)
  cancellationRanges          Json         @default("[]")
  paymentInParWithCancellation Boolean     @default(true)
  paymentRanges               Json         @default("[]")
  mealsConfig              Json         @default("{\"breakfast\":{\"enabled\":false,\"priceAdult\":0,\"priceChild\":0,\"priceInfant\":0},\"lunch\":{\"enabled\":false,\"priceAdult\":0,\"priceChild\":0,\"priceInfant\":0},\"dinner\":{\"enabled\":false,\"priceAdult\":0,\"priceChild\":0,\"priceInfant\":0}}")
  meetingRoomConfig        Json         @default("{\"enabled\":false,\"pricePerDay\":0}")
  freeRoomsConfig          Json         @default("{\"enabled\":false,\"count\":0}")
  groupPolicies            String?
  rateSelection            String       @default("all") // "all" | "group_only"
  ratePriority             Json         @default("[{\"board\":\"RO\",\"isRefundable\":true},{\"board\":\"RO\",\"isRefundable\":false},{\"board\":\"BB\",\"isRefundable\":true},{\"board\":\"BB\",\"isRefundable\":false},{\"board\":\"HB\",\"isRefundable\":true},{\"board\":\"HB\",\"isRefundable\":false},{\"board\":\"FB\",\"isRefundable\":true},{\"board\":\"FB\",\"isRefundable\":false},{\"board\":\"AI\",\"isRefundable\":true},{\"board\":\"AI\",\"isRefundable\":false}]")
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt
}

model PropertyGroupConfig {
  id                          Int          @id @default(autoincrement())
  propertyId                  Int          @unique
  property                    Property     @relation(fields: [propertyId], references: [id])
  organizationId              Int
  organization                Organization @relation(fields: [organizationId], references: [id])
  enabled                     Boolean?
  bookingMode                 String?
  groupEmail                  String?
  pricingDirection            String?
  pricingPct                  Decimal?     @db.Decimal(5, 2)
  cancellationRanges          Json?
  paymentInParWithCancellation Boolean?
  paymentRanges               Json?
  mealsConfig              Json?
  meetingRoomConfig        Json?
  freeRoomsConfig          Json?
  groupPolicies            String?
  rateSelection            String?
  ratePriority             Json?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt

  @@index([organizationId])
}

model IBEVisit {
  id         Int      @id @default(autoincrement())
  sessionId  String
  page       String   @default("home")
  propertyId Int?
  channel    String   @default("b2c")
  device     String   @default("desktop")
  createdAt  DateTime @default(now())

  @@unique([sessionId, page])
  @@index([createdAt])
  @@index([propertyId])
  @@index([page])
  @@index([device])
}

// ── MCP OAuth Clients ─────────────────────────────────────────────────────────
// Registered OAuth 2.0 clients — static (claude_ai) + DCR-registered (ChatGPT).
model OAuthClient {
  id             Int           @id @default(autoincrement())
  clientId       String        @unique
  clientSecret   String
  clientName     String?
  redirectUris   String        // JSON array of allowed redirect URI prefixes
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ── MCP OAuth Identities ──────────────────────────────────────────────────────
// Maps an OAuth provider subject (Auth0 sub) to an org or property scope,
// allowing ChatGPT/Claude.ai connectors to authenticate via OAuth instead of API keys.
model OAuthIdentity {
  id             Int      @id @default(autoincrement())
  provider       String   @default("auth0")
  sub            String   @unique
  organizationId Int?
  propertyId     Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([propertyId])
}

// ── Incentives ────────────────────────────────────────────────────────────────

model IncentiveItem {
  id              Int           @id @default(autoincrement())
  organizationId  Int?          // null = system level
  organization    Organization? @relation(fields: [organizationId], references: [id])
  propertyId      Int?          // non-null = property-scoped (hotel's own item)
  text            String
  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)
  visibleToChains Boolean       @default(false) // system items: chain admins can use in packages
  visibleToHotels Boolean       @default(false) // system/chain items: hotel admins can see
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  packageItems          IncentivePackageItem[]
  chainItemOverrides    IncentiveChainItemOverride[]
  propertyItemOverrides IncentivePropertyItemOverride[]

  @@index([organizationId])
  @@index([propertyId])
}

model IncentiveChainItemOverride {
  id             Int           @id @default(autoincrement())
  organizationId Int
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId         Int
  item           IncentiveItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  disabled       Boolean       @default(false)

  @@unique([organizationId, itemId])
  @@index([organizationId])
}

model IncentivePackage {
  id              Int           @id @default(autoincrement())
  organizationId  Int?          // null = system level
  organization    Organization? @relation(fields: [organizationId], references: [id])
  propertyId      Int?          // non-null = property-scoped (hotel's own package)
  name            String
  isActive        Boolean       @default(true)
  fontSize        String        @default("md")  // 'sm' | 'md' | 'lg' | 'xl'
  visibleToChains Boolean       @default(false) // system packages: visible to chain admins
  visibleToHotels Boolean       @default(false) // system packages: directly assignable at hotel level
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items         IncentivePackageItem[]
  systemSlots   IncentiveSystemSlot[]   @relation("SystemSlotPkg")
  chainSlots    IncentiveChainSlot[]    @relation("ChainSlotPkg")
  propertySlots IncentivePropertySlot[] @relation("PropertySlotPkg")

  @@index([organizationId])
  @@index([propertyId])
}

model IncentiveSystemSlot {
  slot      String            @id  // 'chain_page' | 'hotel_page' | 'room_banner' | 'room_results'
  packageId Int?
  package   IncentivePackage? @relation("SystemSlotPkg", fields: [packageId], references: [id], onDelete: SetNull)
  updatedAt DateTime          @updatedAt
}

model IncentiveChainSlot {
  id             Int               @id @default(autoincrement())
  organizationId Int
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slot           String
  packageId      Int?
  package        IncentivePackage? @relation("ChainSlotPkg", fields: [packageId], references: [id], onDelete: SetNull)
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, slot])
  @@index([organizationId])
}

model IncentivePropertySlot {
  id         Int               @id @default(autoincrement())
  propertyId Int
  slot       String
  packageId  Int?
  package    IncentivePackage? @relation("PropertySlotPkg", fields: [packageId], references: [id], onDelete: SetNull)
  updatedAt  DateTime          @updatedAt

  @@unique([propertyId, slot])
  @@index([propertyId])
}

model IncentivePackageItem {
  id        Int              @id @default(autoincrement())
  packageId Int
  package   IncentivePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  itemId    Int
  item      IncentiveItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  sortOrder Int              @default(0)

  @@unique([packageId, itemId])
}

model IncentivePropertyItemOverride {
  id         Int           @id @default(autoincrement())
  propertyId Int
  itemId     Int
  item       IncentiveItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  disabled   Boolean       @default(false)

  @@unique([propertyId, itemId])
  @@index([propertyId])
}


// ── Translations ──────────────────────────────────────────────────────────────
model Translation {
  id        Int      @id @default(autoincrement())
  locale    String
  namespace String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locale, namespace, key])
  @@index([locale, namespace])
  @@index([locale])
}

model AffiliateProfile {
  id                 Int       @id @default(autoincrement())
  adminUserId        Int       @unique
  adminUser          AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  country            String?
  accountType        String?

  companyName        String?
  websiteUrl         String?
  primaryLanguage    String?

  audienceLocations  Json      @default("[]")
  audienceTypes      Json      @default("[]")
  monthlyTraffic     String?

  promotionMethods   Json      @default("[]")
  runsBrandedKw      Boolean?

  socialInstagram    String?
  socialTiktok       String?
  socialYoutube      String?
  newsletterSize     String?

  hasAffiliateExp    Boolean?
  expIndustries      Json      @default("[]")
  expMonthlyBookings String?

  paymentMethod      String?
  paymentCurrency    String?
  taxId              String?

  termsAgreedAt      DateTime?
  termsVersion       String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
