// DEV SCHEMA — SQLite, no Docker or PostgreSQL needed.
// Used with: prisma migrate dev --schema=prisma/schema.dev.prisma
//
// Production schema is prisma/schema.prisma (PostgreSQL).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Multi-tenancy ─────────────────────────────────────────────────────────────

model Organization {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  hyperGuestOrgId String?  @unique  // demand org ID in HyperGuest system — used at login
  orgType         String   @default("seller")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  adminUsers            AdminUser[]
  orgSettings           OrgSettings?
  orgDesignDefaults     OrgDesignDefaults?
  orgOffersSettings     OrgOffersSettings?
  communicationSettings CommunicationSettings?
  properties            Property[]
  messageRules          MessageRule[]
  priceComparisonOtas   PriceComparisonOta[]
  promoCodes                  PromoCode[]
  affiliates                  Affiliate[]
  campaigns                   Campaign[]
  orgNavItems                 OrgNavItem[]
  onsiteConversionSettings    OnsiteConversionSettings?
  guests                      Guest[]
  trackingPixels              TrackingPixel[]
  orgMarketingSettings        OrgMarketingSettings?
  orgAIConfig                 OrgAIConfig?
  orgAIChannels               OrgAIChannels?
}

// roles: super | admin | observer | user
model AdminUser {
  id             Int           @id @default(autoincrement())
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  email          String        @unique
  passwordHash   String?
  googleId       String?       @unique
  name           String
  role           String        @default("admin")
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  adminUserProperties AdminUserProperty[]

  @@index([organizationId])
}

model AdminUserProperty {
  adminUserId Int
  propertyId  Int
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([adminUserId, propertyId])
}

model Booking {
  id                  Int      @id @default(autoincrement())
  hyperGuestBookingId Int      @unique
  propertyId          Int
  status              String
  checkIn             DateTime
  checkOut            DateTime
  leadGuestFirstName  String
  leadGuestLastName   String
  leadGuestEmail      String
  totalAmount         Decimal
  currency            String
  agencyReference     String?
  affiliateId         String?
  promoCode              String?
  promoDiscountPct       Decimal?
  originalPrice          Decimal?
  cancellationDeadline   DateTime?
  paymentMethod          String
  paymentFlow         String
  stripeIntentId      String?
  isTest              Boolean  @default(false)
  rawResponse         String   // JSON string (SQLite has no native Json type)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  rooms             BookingRoom[]
  stripeRecord      StripePaymentRecord?
  affiliateBooking  AffiliateBooking?
  campaignId        String?
  campaignBooking   CampaignBooking?

  @@index([propertyId])
  @@index([leadGuestEmail])
  @@index([agencyReference])
  @@index([affiliateId])
  @@index([campaignId])
  @@index([createdAt])
}

model Guest {
  id              Int          @id @default(autoincrement())
  organizationId  Int
  organization    Organization @relation(fields: [organizationId], references: [id])
  email           String
  passwordHash    String?
  firstName       String
  lastName        String
  phone           String?
  nationality     String?
  isBlocked       Boolean   @default(false)
  blockedReason   String?
  emailVerified   Boolean   @default(false)
  resetToken      String?
  resetTokenExp   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  notes           GuestNote[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model GuestNote {
  id          Int      @id @default(autoincrement())
  guestId     Int
  guest       Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  authorId    Int?
  authorName  String
  content     String
  createdAt   DateTime @default(now())

  @@index([guestId])
}

model Affiliate {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  propertyId     Int?
  code           String
  name           String
  email          String?
  commissionRate Decimal?
  discountRate   Decimal?     // optional guest-facing price discount (%)
  displayText    String?      // label shown in "Special for [text]" tag
  notes          String?
  isActive       Boolean      @default(true)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  affiliateBookings AffiliateBooking[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([propertyId])
}

model AffiliateBooking {
  id               Int       @id @default(autoincrement())
  bookingId        Int       @unique
  affiliateId      Int
  commissionRate   Decimal
  commissionAmount Decimal
  currency         String
  createdAt        DateTime  @default(now())

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  affiliate Affiliate @relation(fields: [affiliateId], references: [id])

  @@index([affiliateId])
}

model Campaign {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  propertyId     Int?
  code           String
  name           String
  email          String?
  commissionRate Decimal?
  discountRate   Decimal?
  displayText    String?
  notes          String?
  isActive       Boolean      @default(true)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  campaignBookings CampaignBooking[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([propertyId])
}

model CampaignBooking {
  id               Int       @id @default(autoincrement())
  bookingId        Int       @unique
  campaignId       Int
  commissionRate   Decimal
  commissionAmount Decimal
  currency         String
  createdAt        DateTime  @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
}

model BookingRoom {
  id                Int     @id @default(autoincrement())
  bookingId         Int
  hyperGuestItemId  Int
  roomCode          String
  rateCode          String
  board             String
  status            String
  propertyReference String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model SearchSession {
  id          String   @id @default(cuid())
  propertyId  Int
  checkIn     DateTime
  checkOut    DateTime
  guestsParam String
  nationality String?
  currency    String?
  metaJson    String?  // JSON string
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([createdAt])
  @@index([expiresAt])
}

model PromoCode {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  code           String       @unique
  description    String?
  discountType   String
  discountValue  Decimal
  currency       String?
  maxUses        Int?
  usesCount      Int          @default(0)
  propertyId     Int?
  validFrom      DateTime?
  validTo        DateTime?
  validDateType  String       @default("booking")  // "booking" | "stay"
  isActive       Boolean      @default(true)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([code])
  @@index([propertyId])
}

model HotelConfig {
  id                              Int      @id @default(autoincrement())
  propertyId                      Int      @unique

  // ── Localisation (nullable = inherit from OrgDesignDefaults) ────────────────
  defaultCurrency                 String?
  defaultLocale                   String?
  textDirection                   String?                             // "ltr" | "rtl"
  enabledLocales                  String?                             // JSON array
  enabledCurrencies               String?                             // JSON array

  // ── Payment ─────────────────────────────────────────────────────────────────
  onlinePaymentEnabled            Boolean  @default(true)
  payAtHotelEnabled               Boolean  @default(true)
  payAtHotelCardGuaranteeRequired Boolean  @default(false)

  // ── Design tokens (nullable = inherit from OrgDesignDefaults) ───────────────
  colorPrimary                    String?
  colorPrimaryHover               String?
  colorPrimaryLight               String?
  colorAccent                     String?
  colorBackground                 String?
  colorSurface                    String?
  colorText                       String?
  colorTextMuted                  String?
  colorBorder                     String?
  colorSuccess                    String?
  colorError                      String?

  // ── Typography (nullable = inherit from OrgDesignDefaults) ──────────────────
  fontFamily                      String?                             // Google Font name
  borderRadius                    Int?                                // px

  // ── Branding content (nullable = inherit from OrgDesignDefaults) ─────────────
  logoUrl                         String?
  faviconUrl                      String?
  heroImageUrl                    String?
  searchResultsImageUrl           String?
  displayName                     String?  // override property name from HyperGuest
  tagline                         String?
  tabTitle                        String?  // browser tab title; defaults to hotel name

  // ── Guest age configuration ──────────────────────────────────────────────────
  infantMaxAge                    Int      @default(2)   // ages 0–infantMaxAge are infants
  childMaxAge                     Int      @default(16)  // ages up to childMaxAge are children; above are adults
  roomRatesDefaultExpanded        Boolean  @default(false)
  heroStyle                       String   @default("fullpage")  // "fullpage" | "rectangle"
  heroImageMode                   String   @default("fixed")     // "fixed" | "carousel"
  heroCarouselInterval            Int      @default(5)           // seconds between slides
  searchResultsImageMode          String   @default("fixed")     // "fixed" | "carousel"
  searchResultsCarouselInterval   Int      @default(5)           // seconds between slides
  searchResultsExcludedImageIds   String   @default("[]")        // JSON array of excluded image IDs
  excludedPropertyImageIds        String   @default("[]")        // JSON array of image IDs
  excludedRoomImageIds            String   @default("[]")        // JSON array of image IDs
  roomPrimaryImageIds             String   @default("{}")        // JSON map: {roomId: imageId}
  tripadvisorHotelKey             String?                        // e.g. "g293916-d305496"
  priceComparisonEnabled          Boolean  @default(true)

  isActive                        Boolean  @default(true)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

model StripePaymentRecord {
  id               Int      @id @default(autoincrement())
  bookingId        Int?     @unique
  stripeIntentId   String   @unique
  stripeIntentType String
  paymentFlow      String
  amount           Int?
  currency         String?
  status           String
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([stripeIntentId])
}

model NavItem {
  id         String    @id @default(uuid())
  propertyId Int
  section    String    // "header" | "footer"
  label      String
  type       String    // "static" | "link" | "popup"
  url        String?
  content    String?
  order      Int       @default(0)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([propertyId, section])
}

model Property {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  propertyId     Int          @unique  // HyperGuest property ID
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  deletedAt      DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  hyperGuestBearerToken   String?
  hyperGuestStaticDomain  String?
  hyperGuestSearchDomain  String?
  hyperGuestBookingDomain String?

  adminUserProperties AdminUserProperty[]

  @@index([organizationId])
}

model OrgDesignDefaults {
  id                Int          @id @default(autoincrement())
  organizationId    Int          @unique
  organization      Organization @relation(fields: [organizationId], references: [id])

  colorPrimary      String?
  colorPrimaryHover String?
  colorPrimaryLight String?
  colorAccent       String?
  colorBackground   String?
  colorSurface      String?
  colorText         String?
  colorTextMuted    String?
  colorBorder       String?
  colorSuccess      String?
  colorError        String?
  fontFamily        String?
  borderRadius      Int?
  logoUrl           String?
  faviconUrl        String?
  displayName       String?
  tagline           String?
  tabTitle          String?
  defaultCurrency   String?
  defaultLocale     String?
  textDirection     String?
  enabledLocales    String?
  enabledCurrencies String?
  heroStyle                    String?
  heroImageMode                String?
  heroCarouselInterval         Int?
  searchResultsImageUrl        String?
  searchResultsImageMode       String?
  searchResultsCarouselInterval Int?
  roomRatesDefaultExpanded     Boolean?
  infantMaxAge                 Int?
  childMaxAge                  Int?
  onlinePaymentEnabled         Boolean?
  payAtHotelEnabled            Boolean?
  payAtHotelCardGuaranteeRequired Boolean?
  chainHeroImageUrl            String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OrgNavItem {
  id             String       @id @default(uuid())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  section        String
  label          String
  type           String
  url            String?
  content        String?
  order          Int          @default(0)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, section])
}

model OrgSettings {
  id                      Int          @id @default(autoincrement())
  organizationId          Int          @unique
  organization            Organization @relation(fields: [organizationId], references: [id])
  propertyMode            String       @default("single")  // "single" | "multi"
  showCitySelector        Boolean      @default(false)
  showDemoProperty        Boolean      @default(false)
  rateProvider            String       @default("frankfurter")  // exchange rate provider key
  hyperGuestBearerToken   String?
  hyperGuestStaticDomain  String?
  hyperGuestSearchDomain  String?
  hyperGuestBookingDomain String?
  webDomain               String?
  tlsCert                 String?
  tlsKey                  String?
  enabledModels           String       @default("[\"b2c\",\"b2b\"]")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

// ── Communication Settings ────────────────────────────────────────────────────

model CommunicationSettings {
  id             Int          @id @default(autoincrement())
  organizationId Int          @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Email
  emailEnabled      Boolean @default(false)
  emailProvider     String  @default("smtp")
  emailFromName     String  @default("")
  emailFromAddress  String  @default("")
  emailSmtpHost     String  @default("")
  emailSmtpPort     Int     @default(587)
  emailSmtpUser     String  @default("")
  emailSmtpSecure   Boolean @default(true)
  emailSmtpPassword String?
  emailApiKey       String?

  // WhatsApp
  whatsappEnabled           Boolean @default(false)
  whatsappProvider          String  @default("meta")
  whatsappPhoneNumberId     String  @default("")
  whatsappBusinessAccountId String  @default("")
  whatsappAccessToken       String?
  whatsappTwilioAccountSid  String  @default("")
  whatsappTwilioAuthToken   String?
  whatsappTwilioNumber      String  @default("")

  // SMS
  smsEnabled          Boolean @default(false)
  smsProvider         String  @default("twilio")
  smsFromNumber       String  @default("")
  smsTwilioAccountSid String  @default("")
  smsTwilioAuthToken  String?
  smsVonageApiKey     String  @default("")
  smsVonageApiSecret  String?
  smsAwsAccessKey     String  @default("")
  smsAwsSecretKey     String?
  smsAwsRegion        String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Message Rules ─────────────────────────────────────────────────────────────

model MessageRule {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  propertyId     Int?
  name           String
  enabled        Boolean      @default(true)
  channels       String       @default("[]")    // JSON: ["email","whatsapp","sms"]
  trigger        String                         // booking_confirmed | booking_cancelled | cancellation_deadline | checkin | checkout
  offsetValue    Int          @default(0)       // 0 = send immediately
  offsetUnit     String       @default("hours") // hours | days
  direction      String       @default("after") // before | after
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([propertyId])
}

// ── Org Nav Item Property Overrides ──────────────────────────────────────────

model OrgNavItemOverride {
  id           Int     @id @default(autoincrement())
  orgNavItemId String
  propertyId   Int
  isEnabled    Boolean

  @@unique([orgNavItemId, propertyId])
  @@index([propertyId])
}

// ── Property Item Overrides ───────────────────────────────────────────────────

model PropertyItemOverride {
  id         Int     @id @default(autoincrement())
  entityType String
  entityId   Int
  propertyId Int
  isEnabled  Boolean

  @@unique([entityType, entityId, propertyId])
  @@index([entityType, propertyId])
}

// ── Offers Settings ──────────────────────────────────────────────────────────

model OrgOffersSettings {
  id                           Int          @id @default(autoincrement())
  organizationId               Int          @unique
  organization                 Organization @relation(fields: [organizationId], references: [id])
  minNights                    Int?
  maxNights                    Int?
  minRooms                     Int?
  maxRooms                     Int?
  allowedCancellationPolicies  String?
  allowedBoardTypes            String?
  allowedChargeParties         String?
  allowedPaymentMethods        String?
  minOfferValue                Decimal?
  minOfferCurrency             String?
  bookingMode                  String?
  multiRoomLimitBy             String?
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt
}

model PropertyOffersSettings {
  id                           Int      @id @default(autoincrement())
  propertyId                   Int      @unique
  minNights                    Int?
  maxNights                    Int?
  minRooms                     Int?
  maxRooms                     Int?
  allowedCancellationPolicies  String?
  allowedBoardTypes            String?
  allowedChargeParties         String?
  allowedPaymentMethods        String?
  minOfferValue                Decimal?
  minOfferCurrency             String?
  bookingMode                  String?
  multiRoomLimitBy             String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

// ── Onsite Conversion ─────────────────────────────────────────────────────────

model OnsiteConversionSettings {
  id             Int          @id @default(autoincrement())
  organizationId Int          @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  presenceEnabledModels String  @default("[\"b2c\",\"b2b\"]")
  presenceMinViewers    Int     @default(3)
  presenceMessage       String  @default("[xx] people are viewing this property right now")
  presencePages         String  @default("[\"hotel\",\"room\"]")

  bookingsEnabledModels String  @default("[\"b2c\",\"b2b\"]")
  bookingsWindowHours   Int     @default(24)
  bookingsMinCount      Int     @default(1)
  bookingsMessage       String  @default("[xx] rooms booked in the last [hh] hours")
  bookingsPages         String  @default("[\"hotel\",\"room\"]")

  popupEnabledModels String  @default("[]")
  popupDelaySeconds  Int     @default(30)
  popupMessage       String?
  popupPromoCode     String?
  popupPages         String  @default("[\"hotel\",\"room\"]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PropertyOnsiteConversionSettings {
  id         Int @id @default(autoincrement())
  propertyId Int @unique

  presenceEnabledModels String?
  presenceMinViewers    Int?
  presenceMessage       String?
  presencePages         String?

  bookingsEnabledModels String?
  bookingsWindowHours   Int?
  bookingsMinCount      Int?
  bookingsMessage       String?
  bookingsPages         String?

  popupEnabledModels String?
  popupDelaySeconds  Int?
  popupMessage       String?
  popupPromoCode     String?
  popupPages         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Price Comparison OTAs ─────────────────────────────────────────────────────

model PriceComparisonOta {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String                         // e.g. "Booking.com"
  url            String                         // hotel page URL on that OTA
  isEnabled      Boolean      @default(true)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

// ── Price Comparison Cache ────────────────────────────────────────────────────

model PriceComparisonCache {
  id        Int      @id @default(autoincrement())
  otaId     Int
  cacheKey  String   @unique  // "<otaId>:<checkin>:<checkout>:<adults>:<children>"
  price     Decimal?
  currency  String   @default("USD")
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// ── Tracking Pixels ───────────────────────────────────────────────────────────

model TrackingPixel {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  propertyId     Int?
  name           String
  code           String
  pages          String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([propertyId])
}

// ── Marketing Module Settings ─────────────────────────────────────────────────

model OrgMarketingSettings {
  id             Int          @id @default(autoincrement())
  organizationId Int          @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  promoCodesModels       String @default("[\"b2c\",\"b2b\"]")
  priceComparisonModels  String @default("[\"b2c\",\"b2b\"]")
  affiliatesModels       String @default("[\"b2c\",\"b2b\"]")
  campaignsModels        String @default("[\"b2c\",\"b2b\"]")
  onsiteConversionModels String @default("[\"b2c\",\"b2b\"]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PropertyMarketingSettings {
  id         Int     @id @default(autoincrement())
  propertyId Int     @unique

  promoCodesModels       String?
  priceComparisonModels  String?
  affiliatesModels       String?
  campaignsModels        String?
  onsiteConversionModels String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── AI Configuration ──────────────────────────────────────────────────────────

model SystemAIConfig {
  id           Int      @id @default(autoincrement())
  provider     String
  model        String
  apiKey       String
  systemPrompt String?
  enabled      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OrgAIConfig {
  id             Int          @id @default(autoincrement())
  organizationId Int          @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  useInherited   Boolean      @default(true)
  provider       String?
  model          String?
  apiKey         String?
  systemPrompt   String?
  enabled        Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model PropertyAIConfig {
  id           Int      @id @default(autoincrement())
  propertyId   Int      @unique
  useInherited Boolean  @default(true)
  provider     String?
  model        String?
  apiKey       String?
  systemPrompt String?
  enabled      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── AI Channels ───────────────────────────────────────────────────────────────

model OrgAIChannels {
  id             Int          @id @default(autoincrement())
  organizationId Int          @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  aiSearchBarModels String @default("[\"b2c\",\"b2b\"]")
  whatsappModels    String @default("[]")
  mcpModels         String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
