{
  "name": "@ibe/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "node --env-file=.env --watch --import /home/nir/ibe/node_modules/.pnpm/tsx@4.21.0/node_modules/tsx/dist/esm/index.mjs src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:generate:dev": "prisma generate --schema=prisma/schema.dev.prisma",
    "db:migrate": "prisma migrate dev",
    "db:migrate:dev": "prisma migrate dev --schema=prisma/schema.dev.prisma",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:studio:dev": "prisma studio --schema=prisma/schema.dev.prisma",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/oauth2": "^7.9.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/sensible": "^5.0.0",
    "@fastify/static": "^9.1.1",
    "@ibe/shared": "workspace:*",
    "@prisma/client": "^5.12.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^4.27.0",
    "ioredis": "^5.3.0",
    "nodemailer": "^8.0.6",
    "pino": "^9.0.0",
    "playwright": "^1.59.1",
    "stripe": "^22.0.1",
    "undici": "^6.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@vitest/coverage-v8": "^1.5.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.12.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
